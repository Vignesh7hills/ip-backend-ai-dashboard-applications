# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── File limits ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Company ───────────────────────────────────────────────────────────────────
COMPANY_NAME=Diginnovators

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://ip_ai_dashboard_application_p_user:48sSzRJxYb2e2MXRo1QSrusUBmMThuJK@dpg-d8fvv7beo5us73fu5tu0-a.oregon-postgres.render.com/ip_ai_dashboard_application_p

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRE_MINUTES=60

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@diginnovators.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000
